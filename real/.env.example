# Drone 2026 physical target overrides.
# Copy to real/.env for local secrets. Loaded when Elytra Bridge connects in real mode.
# Precedence: real/.env, then Elytra Bridge backend environment, then project.yaml.

# Replace with your flight computer reachable from the machine running Elytra Bridge.
DRONE_HOST=REPLACE_WITH_DRONE_HOSTNAME_OR_IP
DRONE_PORT=22
DRONE_USER=REPLACE_WITH_SSH_USER

# Use a key, a password, or both. Key auth is preferred for automation.
DRONE_PRIVATE_KEY_PATH=REPLACE_WITH_ABSOLUTE_PATH_TO_PRIVATE_KEY
# DRONE_PRIVATE_KEY_PASSPHRASE=
# DRONE_SSH_PASSWORD=INSERTPASSWORDHERE

DRONE_START_SCRIPT_PATH=/home/pi/drone_workspace/drone-2026/buttons/scripts/start_drone.sh
DRONE_RECORDING_SCRIPT_PATH=/home/pi/drone_workspace/drone-2026/buttons/scripts/start_recording.sh
DRONE_MISSION_DIR=/home/pi/drone_workspace/drone-2026/ros_workspace/src/uav_mission/missions
DRONE_ROS_INSTALL=/home/pi/drone_workspace/drone-2026/ros_workspace/install/setup.bash
DRONE_TMUX_SESSION=drone_control
DRONE_TMUX_CAPTURE_LINES=2500
DRONE_TMUX_STOP_GRACE_SECONDS=60

# Optional launch overrides.
DRONE_MISSION_EXTRA_ARGS=
