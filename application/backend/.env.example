PORT=8787
DRONE_HOST=100.105.25.30
DRONE_PORT=22
DRONE_USER=pi
# Use a key, a password, or both (key is preferred for automation).
DRONE_PRIVATE_KEY_PATH=C:/Users/isaac/.ssh/id_ed25519
# Optional: key file passphrase (not the SSH login password)
# DRONE_PRIVATE_KEY_PASSPHRASE=
# Optional: SSH account password — stored in plain text in .env
# DRONE_SSH_PASSWORD=INSERTPASSWORDHERE
DRONE_START_SCRIPT_PATH=/home/pi/drone_workspace/drone-2026/start_drone.sh
DRONE_RECORDING_SCRIPT_PATH=/home/pi/drone_workspace/drone-2026/start_recording.sh
DRONE_MISSION_DIR=/home/pi/drone_workspace/drone-2026/ros_workspace/src/uav_mission/missions
DRONE_ROS_INSTALL=/home/pi/drone_workspace/drone-2026/ros_workspace/install/setup.bash
DRONE_TMUX_SESSION=drone_control
# Optional: override MAVROS FCU URL for physical mode (defaults to script's serial URL)
DRONE_MAVROS_FCU_URL=
# Optional: extra ros2 launch args appended in physical mode (space-separated)
DRONE_MISSION_EXTRA_ARGS=
# Optional: lines of tmux scrollback for the web log panel (default 2500)
# DRONE_TMUX_CAPTURE_LINES=2500
# Seconds to wait after Ctrl+C before tmux kill-session (rosbag finalize); default 20
DRONE_TMUX_STOP_GRACE_SECONDS=60

# --- Local simulation (Docker SITL) ---
# Set this to your compose file path if different from repo default.
# SIM_COMPOSE_FILE=C:/Users/isaac/Desktop/UAVsAtBerkeley/drone-2026/SITL/web-sim/docker-compose.yml
# Optional compose project override. Leave empty to use Docker Compose default project naming.
# SIM_COMPOSE_PROJECT=
# Optional: container name to target for docker exec/cp transport in sim mode.
SIM_CONTAINER_NAME=drone-2026-sim
SIM_SSH_HOST=127.0.0.1
SIM_SSH_PORT=22220
SIM_SSH_USER=sim
# Optional key auth for simulation SSH
SIM_PRIVATE_KEY_PATH=
# SIM_PRIVATE_KEY_PASSPHRASE=
# Password used by backend when connecting into simulation container
SIM_SSH_PASSWORD=sim
SIM_DRONE_START_SCRIPT_PATH=/home/sim/drone_workspace/drone-2026/start_drone.sh
SIM_DRONE_RECORDING_SCRIPT_PATH=/home/sim/drone_workspace/drone-2026/start_recording.sh
SIM_DRONE_MISSION_DIR=/home/sim/drone_workspace/drone-2026/ros_workspace/src/uav_mission/missions
SIM_DRONE_ROS_INSTALL=/home/sim/drone_workspace/drone-2026/ros_workspace/install/setup.bash
SIM_DRONE_TMUX_SESSION=drone_control
SIM_DRONE_TMUX_CAPTURE_LINES=2500
SIM_DRONE_TMUX_STOP_GRACE_SECONDS=20
SIM_MAVROS_FCU_URL=udp://:14540@
# Keep use_sim_time off by default unless your stack publishes /clock.
SIM_DRONE_MISSION_EXTRA_ARGS=include_camera:=false
SIM_NOVNC_ORIGIN=http://127.0.0.1:6080/vnc.html?autoconnect=1&resize=scale&path=websockify
# If 1, backend tears down docker compose when switching away from sim mode.
SIM_AUTOSTOP_ON_DISCONNECT=0
RECONNECT_BACKOFF_MS=3000
